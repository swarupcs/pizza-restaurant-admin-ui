# Admin UI - Environment Variables Example
# Vite exposes env vars prefixed with VITE_ to the browser.
# Copy this file to .env.local and fill in your values.

# Backend API gateway base URL (all service requests route through this)
VITE_BACKEND_API_URL=http://localhost:8080

# WebSocket service URL (for real-time order updates)
VITE_SOCKET_SERVICE_URL=http://localhost:5504
